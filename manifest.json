{
  "manifest_version": 3,
  "name": "Schedule to Calendar Converter",
  "version": "2.0.1",
  "description": "Converts schedule on Banner to .ics file, allowing users to directly add classes on their device calendar",
  "author": "Sir Jal",
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_title": "Schedule to Calendar Converter"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [],
  "icons": {
    "128": "src/images/extension logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/classes/*.js",
        "src/utils/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}